#!/usr/bin/env bash
# Two-way sync for the learning repo.
#   pull: lessons generated by the daily-lessons workflow (committed by the bot)
#   push: your local practice code and notes — the nightly generator reads the
#         repo's copy, so unpushed work is invisible to it.
set -euo pipefail
cd "$HOME/learning"

git pull --rebase --autostash origin main

if [ -n "$(git status --porcelain)" ]; then
  git add -A
  git commit -m "practice: $(date +%F)"
  git push origin main
  echo "pushed local work ⬆️"
fi
echo "learning repo in sync ✅"
